{
  "comments": {
    "lineComment": "~"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[",  "close": "]"  },
    { "open": "(",  "close": ")"  },
    { "open": "\"", "close": "\"" },
    { "open": "'",  "close": "'"  }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_\\-]*",
  "indentationRules": {
    "increaseIndentPattern": "^:[a-z][a-z0-9_-]*\\s*$",
    "decreaseIndentPattern": "^(===\\s+/|@|~|#|>)"
  },
  "folding": {
    "markers": {
      "start": "^===\\s+[A-Z]",
      "end":   "^===\\s+/"
    }
  }
}
