{
  "comments": {
    "lineComment": "~"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[",  "close": "]"  },
    { "open": "(",  "close": ")"  },
    { "open": "\"", "close": "\"" },
    { "open": "'",  "close": "'"  }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_\\-]*",
  "indentationRules": {
    "increaseIndentPattern": "^:[a-z][a-z0-9_-]*\\s*$",
    "decreaseIndentPattern": "^(:::?[A-Za-z]|@|~|#|>)"
  },
  "folding": {
    "markers": {
      "start": "^:::?[A-Za-z][A-Za-z0-9_]*",
      "end":   "^:::?[A-Za-z][A-Za-z0-9_]*"
    }
  }
}
