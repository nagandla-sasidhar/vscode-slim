{
  "name": "slim-language",
  "displayName": "SLIM — Structured LLM Instruction Markup",
  "description": "Syntax highlighting, snippets, and language support for .slm files (Structured LLM Instruction Markup)",
  "version": "2.0.0",
  "publisher": "slim-format",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/nagandla-sasidhar/vscode-slim"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": ["slim", "slm", "llm", "ai", "prompt", "markdown", "agent"],
  "contributes": {
    "languages": [
      {
        "id": "slim",
        "aliases": ["SLIM", "slim", "Structured LLM Instruction Markup"],
        "extensions": [".slm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "slim",
        "scopeName": "source.slim",
        "path": "./syntaxes/slim.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "slim",
        "path": "./snippets/slim.json"
      }
    ],
    "configurationDefaults": {
      "[slim]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.wordWrap": "on"
      }
    },
    "configuration": {
      "title": "SLIM",
      "properties": {
        "slim.validate": {
          "type": "boolean",
          "default": true,
          "description": "Enable basic SLIM validation (malformed headers, invalid sections)"
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package"
  }
}
